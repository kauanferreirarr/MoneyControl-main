{
  "version": 2,
  "builds": [
    { "src": "index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/processar_extrato", "dest": "/index.js" },
    { "src": "/ping", "dest": "/index.js" },

    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },

    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
